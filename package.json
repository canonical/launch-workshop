{
  "name": "launch-workshop",
  "description": "GitHub Action to launch a workshop (development environment)",
  "version": "0.2.0",
  "author": "Canonical",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/canonical/launch-workshop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canonical/launch-workshop.git"
  },
  "bugs": {
    "url": "https://github.com/canonical/launch-workshop/issues"
  },
  "keywords": [
    "actions",
    "workshop"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx --node-options '--experimental-vm-modules --no-warnings' -- jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "inspect": "npx --node-options '--experimental-vm-modules --inspect-brk --no-warnings' -- jest --coverage=false --runInBand",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin 'typescript={include:\"rollup.config.ts\"}'",
    "package:watch": "npm run package -- --watch",
    "test": "npx --node-options '--experimental-vm-modules --no-warnings' -- jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "LGPL-3.0-only",
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@fetch-mock/jest": "^0.2.16",
    "@jest/globals": "^30.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.5.1",
    "jest": "^30.0.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.44.1",
    "ts-jest": "^29.4.0",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
