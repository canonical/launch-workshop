SDK="$(pwd)"

mkdir /opt/node
cd /opt

curl -fsSLO 'https://nodejs.org/dist/v20.19.1/node-v20.19.1-linux-x64.tar.xz'
sha256sum -c "${SDK}/SHASUMS256.txt" --ignore-missing

cd node
tar xf ../node-v20.19.1-linux-x64.tar.xz --strip-components 1
rm ../node-v20.19.1-linux-x64.tar.xz

echo "PATH=/opt/node/bin:$PATH" | tee -a /home/workshop/.profile
